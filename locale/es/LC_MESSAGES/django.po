# Invitation response templates
#: templates/emails/invitation_accepted.html:4
msgid "Invitation Accepted"
msgstr "Invitación Aceptada"

#: templates/emails/invitation_accepted.html:7
msgid "Invitation Accepted!"
msgstr "¡Invitación Aceptada!"

#: templates/emails/invitation_accepted.html:10
#, python-format
msgid ""
"\n"
"        Hi %(user_name)s, congratulations! You have successfully accepted the invitation to join %(band_name)s.\n"
"        "
msgstr ""
"\n"
"¡Hola %(user_name)s, felicitaciones! Has aceptado exitosamente la invitación para unirte a %(band_name)s.\n"
"        "

#: templates/emails/invitation_accepted.html:15
msgid "You are now a member of the band and can start collaborating with your bandmates, managing projects, and sharing your music with the world."
msgstr "Ahora eres miembro de la banda y puedes comenzar a colaborar con tus compañeros de banda, gestionar proyectos y compartir tu música con el mundo."

#: templates/emails/invitation_accepted.html:22
msgid "View Band Profile"
msgstr "Ver Perfil de la Banda"

#: templates/emails/invitation_declined.html:4
msgid "Invitation Declined"
msgstr "Invitación Rechazada"

#: templates/emails/invitation_declined.html:10
#, python-format
msgid ""
"\n"
"        Hi %(user_name)s, you have declined the invitation to join %(band_name)s.\n"
"        "
msgstr ""
"\n"
"Hola %(user_name)s, has rechazado la invitación para unirte a %(band_name)s.\n"
"        "

#: templates/emails/invitation_declined.html:15
msgid "The band owner has been notified of your decision. You can always accept future invitations from other bands or create your own music project."
msgstr "El propietario de la banda ha sido notificado de tu decisión. Siempre puedes aceptar futuras invitaciones de otras bandas o crear tu propio proyecto musical."

#: templates/emails/invitation_error.html:4
msgid "Invitation Error"
msgstr "Error en la Invitación"

#: templates/emails/invitation_error.html:7
msgid "Unable to Process Invitation"
msgstr "No se Pudo Procesar la Invitación"

#: templates/emails/invitation_error.html:10
#, python-format
msgid ""
"\n"
"        Hi %(user_name)s, we encountered an issue while processing your invitation response.\n"
"        "
msgstr ""
"\n"
"Hola %(user_name)s, encontramos un problema al procesar tu respuesta a la invitación.\n"
"        "

#: templates/emails/invitation_error.html:19
msgid "This could happen for several reasons:"
msgstr "Esto puede ocurrir por varias razones:"

#: templates/emails/invitation_error.html:23
msgid "The invitation has expired"
msgstr "La invitación ha expirado"

#: templates/emails/invitation_error.html:24
msgid "The invitation has already been accepted or declined"
msgstr "La invitación ya ha sido aceptada o rechazada"

#: templates/emails/invitation_error.html:25
msgid "The invitation link is invalid or corrupted"
msgstr "El enlace de la invitación es inválido o está corrupto"

#: templates/emails/invitation_error.html:26
msgid "The invitation has been cancelled by the band owner"
msgstr "La invitación ha sido cancelada por el propietario de la banda"

#: templates/emails/invitation_error.html:41
msgid "If you believe this is an error or need assistance, please contact our support team or ask the band owner to send you a new invitation."
msgstr "Si crees que esto es un error o necesitas asistencia, por favor contacta a nuestro equipo de soporte o pide al propietario de la banda que te envíe una nueva invitación."

# View error messages for invitation processing
#: musicians/views.py:693
msgid "The invitation has expired."
msgstr "La invitación ha expirado."

#: musicians/views.py:700
msgid "The invitation has already been accepted or declined."
msgstr "La invitación ya ha sido aceptada o rechazada."

#: musicians/views.py:708
msgid "Invalid action. Please use the link from your invitation email."
msgstr "Acción inválida. Por favor usa el enlace de tu correo de invitación."

#: musicians/views.py:717
msgid "Missing authentication token. Please use the link from your invitation email."
msgstr "Falta el token de autenticación. Por favor usa el enlace de tu correo de invitación."

#: musicians/views.py:796
msgid "An unexpected error occurred. Please try again or contact support."
msgstr "Ocurrió un error inesperado. Por favor intenta de nuevo o contacta a soporte."
