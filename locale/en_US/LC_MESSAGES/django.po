msgid "Email Verified Successfully"
msgstr "Email Verified Successfully"

#: templates/emails/email_verification_success.html:7
msgid "Email Verified Successfully!"
msgstr "Email Verified Successfully!"

#: templates/emails/email_verification_success.html:10
#, python-format
