#: templates/emails/email_verification_error.html:4
#: templates/emails/email_verification_error.html:7
msgid "Email Verification Failed"
msgstr "Email Verification Failed"

#: templates/emails/email_verification_error.html:13
msgid ""
"We're sorry, but we couldn't verify your email address. The verification "
"link may be invalid or has expired."
msgstr ""
"We're sorry, but we couldn't verify your email address. The verification "
"link may be invalid or has expired."

#: templates/emails/email_verification_error.html:18
msgid ""
"Don't worry! You can request a new verification email to complete the "
"activation of your Altempo account."
msgstr ""
"Don't worry! You can request a new verification email to complete the "
"activation of your Altempo account."

#: templates/emails/email_verification_error.html:25
msgid "Go to Altempo"
msgstr "Go to Altempo"

#: templates/emails/email_verification_error.html:32
msgid ""
"If you continue to experience issues, please contact our support team for "
"assistance."
msgstr ""
"If you continue to experience issues, please contact our support team for "
"assistance."

